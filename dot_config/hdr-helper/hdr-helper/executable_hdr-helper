#!/bin/bash

VERSION=1.3.1
CONFIG_PATH="$HOME/.config/hdr-helper/"
CONFIG_FILE="$CONFIG_PATH/monitor.conf"
CURR_BRIGHT_LVL_PATH="/tmp/hdr-helper/"
CURR_BRIGHT_LVL_FILE="$CURR_BRIGHT_LVL_PATH/current-brightness-level"

# ----------------------
# Helper Functions
# ----------------------

show_hdr_status() {
    ICON="/usr/share/icons/breeze-dark/devices/64/monitor.svg"
    # Use original working grep method
    if [[ $(kscreen-doctor -o | grep -A 15 "$MONITOR" | grep HDR) == *"enabled"* ]]; then
        notify-send -t 5000 -a "HDR Helper" -i "$ICON" "HDR Enabled"
    else
        notify-send -t 5000 -a "HDR Helper" -i "$ICON" "HDR Disabled"
    fi
}

set_brightness() {
    mkdir -p "$CURR_BRIGHT_LVL_PATH"

    # Save current brightness
    kscreen-doctor -o | grep Brightness | head -n1 | grep -oP "(?<=set to )[0-9]+" \
        > "$CURR_BRIGHT_LVL_FILE"

    # Apply SDR target if set
    if [ -v SDR_TARGET_BRIGHTNESS ]; then
        kscreen-doctor output."$MONITOR".brightness."$SDR_TARGET_BRIGHTNESS"
    fi

    if [ -v SDR_TARGET_BRIGHTNESS_NITS ]; then
        kscreen-doctor output."$MONITOR".sdr-brightness."$SDR_TARGET_BRIGHTNESS_NITS"
    fi
}

restore_brightness() {
    if [ -f "$CURR_BRIGHT_LVL_FILE" ]; then
        kscreen-doctor output."$MONITOR".brightness."$(cat "$CURR_BRIGHT_LVL_FILE")"
        rm "$CURR_BRIGHT_LVL_FILE"
    fi
}

refresh_display() {
    kscreen-doctor output."$MONITOR".mode."$TEMP_RES" > /dev/null 2>&1
    kscreen-doctor output."$MONITOR".mode."$NATIVE_RES" > /dev/null 2>&1
}

enable_hdr() {
    kscreen-doctor output."$MONITOR".hdr.enable > /dev/null 2>&1
    kscreen-doctor output."$MONITOR".wcg.enable > /dev/null 2>&1
    refresh_display
    set_brightness
    show_hdr_status
}

disable_hdr() {
    kscreen-doctor output."$MONITOR".hdr.disable > /dev/null 2>&1
    kscreen-doctor output."$MONITOR".wcg.disable > /dev/null 2>&1
    refresh_display
    restore_brightness
    show_hdr_status
}

auto_hdr() {
    if [[ $(kscreen-doctor -o | grep -A 15 "$MONITOR" | grep HDR) == *"enabled"* ]]; then
        disable_hdr
    else
        enable_hdr
    fi
}

show_version() {
    echo "HDR Helper v$VERSION"
}

show_help() {
    cat <<EOF
=== Usage ===
Default behavior toggles HDR:
    hdr-helper
Force enable HDR:
    hdr-helper -e | --enable
Force disable HDR:
    hdr-helper -d | --disable
Show HDR status notification:
    hdr-helper -s | --status
Show version:
    hdr-helper -v | --version
Show help:
    hdr-helper -h | --help

Ensure you are on KDE Plasma with Wayland and that kscreen-doctor is installed.
Configure your monitor in $CONFIG_FILE.
EOF
}

# ----------------------
# Pre-checks
# ----------------------

if ! command -v kscreen-doctor &>/dev/null; then
    echo "Error: kscreen-doctor not found. KDE Plasma with Wayland is required."
    exit 1
fi

# Load config
if ! source "$CONFIG_FILE"; then
    echo "Error: monitor.conf not found or invalid."
    exit 2
fi

if [[ -z "$MONITOR" || -z "$NATIVE_RES" || -z "$TEMP_RES" ]]; then
    echo "Error: monitor.conf not fully configured."
    exit 3
fi

# ----------------------
# Command-line Handling
# ----------------------

case "$1" in
    -e|--enable) enable_hdr ;;
    -d|--disable) disable_hdr ;;
    -s|--status) show_hdr_status ;;
    -v|--version) show_version ;;
    -h|--help) show_help ;;
    "") auto_hdr ;;  # no args
    *) show_help ;;
esac
